# .env — local-only secrets and paths
# This file is gitignored. Do not commit it.
# Only needed when local-only sources are enabled.

# Required if 'git' source is enabled (local only).
# Colon-separated absolute paths to your local git repos.
STANDUP_LOCAL_REPOS=

# Required if 'confluence-self-hosted' source is enabled (local only).
STANDUP_CONFLUENCE_TOKEN=
